<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.PromptTemplateMapper">

    <!-- 基础结果映射 -->
    <resultMap id="BaseResultMap" type="com.example.entity.PromptTemplate">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="name" property="name" jdbcType="VARCHAR"/>
        <result column="content" property="content" jdbcType="VARCHAR"/>
        <result column="description" property="description" jdbcType="VARCHAR"/>
        <result column="category" property="category" jdbcType="VARCHAR"/>
        <result column="version" property="version" jdbcType="VARCHAR"/>
        <result column="is_active" property="isActive" jdbcType="VARCHAR"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
        <result column="create_by" property="createBy" jdbcType="VARCHAR"/>
        <result column="update_by" property="updateBy" jdbcType="VARCHAR"/>
        <result column="is_delete" property="deleted" jdbcType="BOOLEAN"/>
    </resultMap>

    <!-- 通用查询列 -->
    <sql id="Base_Column_List">
        id, name, content, description, category, version, is_active as isActive,
        create_time, update_time, create_by, update_by, is_delete
    </sql>

    <!-- 根据分类查询启用的模板 -->
    <select id="selectActiveByCategory" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM prompt_templates
        WHERE category = #{category}
        AND is_active = '1'
        AND is_delete = 0
        ORDER BY create_time DESC
    </select>

    <!-- 根据名称查询模板 -->
    <select id="selectByName" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM prompt_templates
        WHERE name = #{name}
        AND is_delete = 0
        LIMIT 1
    </select>

    <!-- 批量更新模板状态 -->
    <update id="batchUpdateStatus">
        UPDATE prompt_templates
        SET is_active = #{isActive},
        update_time = NOW()
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <!-- 自定义查询示例：模糊搜索 -->
    <select id="searchByKeyword" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM prompt_templates
        WHERE is_delete = 0
        <if test="keyword != null and keyword != ''">
            AND (name LIKE CONCAT('%', #{keyword}, '%')
            OR description LIKE CONCAT('%', #{keyword}, '%')
            OR content LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        <if test="category != null and category != ''">
            AND category = #{category}
        </if>
        <if test="isActive != null">
            AND is_active = #{isActive}
        </if>
        ORDER BY update_time DESC
    </select>

</mapper>